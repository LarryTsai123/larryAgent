{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "evidence",
    "logs"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "evidence": {
      "type": "object"
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}