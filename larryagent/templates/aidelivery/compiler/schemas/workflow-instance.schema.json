        "properties": {
          "id": {
            "type": "string"
          },
          "capability": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "success_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failure_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_required": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "on_success": {
            "type": "string"
          },
          "on_failure": {
            "type": "string"
          }
