      "type": "string"
    },
    "template": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "capability",
          "depends_on",
          "inputs",
          "outputs",
          "success_criteria",
          "failure_codes",
